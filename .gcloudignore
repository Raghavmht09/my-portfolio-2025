# Ignore development dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore Next.js build files
.next/
out/

# Ignore environment variables
.env*

# Ignore IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Ignore OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore git files
.git/
.gitignore

# Ignore documentation and non-essential files
README.md
CLAUDE.md
docs/
.claude/

# Ignore test files
*.test.js
*.test.ts
*.spec.js
*.spec.ts
__tests__/
coverage/

# Ignore TypeScript build info
*.tsbuildinfo

# Ignore linting files
.eslintrc.*
.prettierrc.*
